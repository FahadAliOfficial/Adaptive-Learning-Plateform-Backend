# Environment Variables for FYP Backend

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/fyp_db

# Example for production:
# DATABASE_URL=postgresql://prod_user:secure_password@db.example.com:5432/fyp_production

# Instructions:
# 1. Copy this file to .env
# 2. Replace with your actual database credentials
# 3. Never commit .env to version control!


GEMINI_API_KEY=your_api_key_here_replace_this

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Environment
ENVIRONMENT=development
